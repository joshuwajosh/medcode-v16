# MedCode V16 Environment Configuration
# ======================================

# ── Application ─────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
APP_ENV=production

# ── Database (PostgreSQL) ──────────────────────────────────────────
DATABASE_URL=postgresql://medcode:changeme@localhost:5432/medcode
DB_HOST=localhost
DB_PORT=5432
DB_NAME=medcode
DB_USER=medcode
DB_PASSWORD=changeme
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30

# ── Redis ───────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=changeme
REDIS_MAX_CONNECTIONS=20

# ── API Keys (set in production) ───────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── HIPAA: PHI masking ─────────────────────────────────────────────
PHI_MASKING_ENABLED=true
AUDIT_LOG_PATH=/app/logs/audit.log

# ── Security ───────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ── CORS ───────────────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# ── SSL (production) ───────────────────────────────────────────────
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# ── Logging ────────────────────────────────────────────────────────
LOG_FORMAT=json
LOG_FILE=/app/logs/medcode.log
LOG_MAX_SIZE=10485760
LOG_BACKUP_COUNT=30

# ── Feature flags ──────────────────────────────────────────────────
V16_MODIFIER_ENGINE=true
V16_EM_ENGINE=true
V16_DOC_QUALITY=true
V16_PHYSICIAN_QUERIES=true
V16_MEDICAL_NECESSITY=true
V16_CONTEXT_CLASSIFIER=true
