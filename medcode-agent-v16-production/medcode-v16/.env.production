# MedCode AI V16 — Production Environment Configuration
# =====================================================
# Copy this file to .env and fill in the values before deployment.
# WARNING: Never commit .env to version control!

# ── Application Settings ─────────────────────────────────────────────
# Host address to bind the application server
APP_HOST=0.0.0.0

# Port for the application server
APP_PORT=8000

# Application environment (development/staging/production)
APP_ENV=production

# Logging level (DEBUG/INFO/WARNING/ERROR/CRITICAL)
LOG_LEVEL=INFO

# Application name for logging and identification
APP_NAME=MedCode-AI

# ── Database Configuration (PostgreSQL) ──────────────────────────────
# Full database connection URL
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://medcode:CHANGE_ME@postgres:5432/medcode

# Database host (use container name in Docker)
DB_HOST=postgres

# Database port
DB_PORT=5432

# Database name
DB_NAME=medcode

# Database user
DB_USER=medcode

# Database password (CHANGE THIS!)
DB_PASSWORD=CHANGE_ME

# Connection pool size (recommend: CPU cores * 2 + disk spindles)
DB_POOL_SIZE=10

# Maximum overflow connections
DB_MAX_OVERFLOW=20

# Pool timeout in seconds
DB_POOL_TIMEOUT=30

# ── Redis Configuration ──────────────────────────────────────────────
# Full Redis connection URL
REDIS_URL=redis://redis:6379/0

# Redis password (CHANGE THIS!)
REDIS_PASSWORD=CHANGE_ME

# Maximum Redis connections
REDIS_MAX_CONNECTIONS=20

# Redis max memory (in Redis format: 256mb, 1gb, etc.)
REDIS_MAX_MEMORY=256mb

# Redis eviction policy
REDIS_EVICTION_POLICY=allkeys-lru

# ── Security Settings ────────────────────────────────────────────────
# JWT secret key for token signing (64 characters minimum)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING

# Application secret key for signing
# Generate with: openssl rand -hex 32
SECRET_KEY=CHANGE_ME_64_CHAR_HEX_STRING

# Fernet encryption key for sensitive data
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
MEDCODE_ENCRYPTION_KEY=CHANGE_ME_FERNET_KEY

# API key header name for third-party integrations
API_KEY_HEADER=X-API-Key

# Enable API key authentication
API_KEY_AUTH_ENABLED=true

# Rate limiting: requests per minute per client
RATE_LIMIT_PER_MINUTE=100

# Rate limiting: burst allowance
RATE_LIMIT_BURST=20

# Session timeout in seconds (default: 24 hours)
SESSION_TIMEOUT=86400

# ── HIPAA Compliance ─────────────────────────────────────────────────
# Enable PHI (Protected Health Information) masking
PHI_MASKING_ENABLED=true

# Path to audit log file
AUDIT_LOG_PATH=/app/logs/audit.log

# Audit log retention in days
AUDIT_LOG_RETENTION_DAYS=90

# Enable audit logging for all API requests
AUDIT_LOG_ALL_REQUESTS=true

# PHI detection confidence threshold (0.0 to 1.0)
PHI_DETECTION_THRESHOLD=0.85

# ── AI Model Configuration ──────────────────────────────────────────
# Anthropic API key (for AI-powered features)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Model to use for coding suggestions
AI_MODEL=claude-3-sonnet-20240229

# Maximum tokens for AI responses
AI_MAX_TOKENS=4096

# AI temperature (0.0 to 1.0)
AI_TEMPERATURE=0.1

# ── CORS Configuration ──────────────────────────────────────────────
# Allowed origins (comma-separated list in JSON format)
CORS_ORIGINS=["https://yourdomain.com","https://app.yourdomain.com"]

# Allowed HTTP methods
CORS_ALLOW_METHODS=["GET","POST","PUT","DELETE","OPTIONS","PATCH"]

# Allowed headers
CORS_ALLOW_HEADERS=["Authorization","Content-Type","X-API-Key","X-Request-ID"]

# Allow credentials (cookies, authorization headers)
CORS_ALLOW_CREDENTIALS=true

# ── SSL/TLS Configuration ──────────────────────────────────────────
# Path to SSL certificate file
SSL_CERT_PATH=/etc/nginx/ssl/fullchain.pem

# Path to SSL private key file
SSL_KEY_PATH=/etc/nginx/ssl/privkey.pem

# Path to SSL certificate chain (optional)
SSL_CHAIN_PATH=/etc/nginx/ssl/chain.pem

# Enable HSTS (HTTP Strict Transport Security)
SSL_HSTS_ENABLED=true

# HSTS max age in seconds (default: 1 year)
SSL_HSTS_MAX_AGE=31536000

# ── Logging Configuration ───────────────────────────────────────────
# Log format (json/text)
LOG_FORMAT=json

# Log file path
LOG_FILE=/app/logs/medcode.log

# Maximum log file size in bytes (10MB)
LOG_MAX_SIZE=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=30

# Enable request logging
REQUEST_LOGGING=true

# Log slow requests threshold in seconds
SLOW_REQUEST_THRESHOLD=5.0

# ── Feature Flags ───────────────────────────────────────────────────
# Enable Modifier Engine
V16_MODIFIER_ENGINE=true

# Enable EM Engine (Evaluation & Management)
V16_EM_ENGINE=true

# Enable Documentation Quality checks
V16_DOC_QUALITY=true

# Enable Physician Query generation
V16_PHYSICIAN_QUERIES=true

# Enable Medical Necessity checks
V16_MEDICAL_NECESSITY=true

# Enable Context Classifier
V16_CONTEXT_CLASSIFIER=true

# Enable CPT Reasoning
V16_CPT_REASONING=true

# Enable Batch Processing
V16_BATCH_PROCESSING=true

# ── Monitoring & Observability ──────────────────────────────────────
# Enable Prometheus metrics
PROMETHEUS_ENABLED=false

# Metrics port (if Prometheus enabled)
METRICS_PORT=9090

# Enable distributed tracing
TRACING_ENABLED=false

# Tracing endpoint (Jaeger/Zipkin)
TRACING_ENDPOINT=http://jaeger:14268/api/traces

# Enable health check logging
HEALTH_CHECK_LOGGING=false

# ── Backup Configuration ────────────────────────────────────────────
# Backup directory path
BACKUP_DIR=/app/backups

# Backup retention in days
BACKUP_RETENTION_DAYS=30

# Enable automated backups
AUTO_BACKUP_ENABLED=true

# Backup schedule (cron format: minute hour day month weekday)
BACKUP_SCHEDULE=0 2 * * *

# ── Docker Configuration ────────────────────────────────────────────
# Docker Compose project name
COMPOSE_PROJECT_NAME=medcode

# Docker network name
DOCKER_NETWORK=medcode_network

# Enable Docker BuildKit
DOCKER_BUILDKIT=1

# ── Notification Settings ───────────────────────────────────────────
# Enable email notifications
EMAIL_NOTIFICATIONS=false

# SMTP server
SMTP_HOST=smtp.gmail.com

# SMTP port
SMTP_PORT=587

# SMTP username
SMTP_USER=your-email@gmail.com

# SMTP password
SMTP_PASSWORD=your-app-password

# Notification email recipients (comma-separated)
NOTIFICATION_EMAILS=admin@yourdomain.com

# ── Security Notes ──────────────────────────────────────────────────
# 
# IMPORTANT SECURITY REMINDERS:
# 
# 1. NEVER commit this file to version control
# 2. Use strong, randomly generated passwords for all secrets
# 3. Rotate secrets regularly (at least every 90 days)
# 4. Use different passwords for each environment (dev/staging/prod)
# 5. Restrict access to this file (chmod 600 .env)
# 6. Use environment variable injection in production if possible
# 7. Monitor access to this file
# 8. Use a secrets manager (Vault, AWS Secrets Manager, etc.) in production
#
# Generate secure values:
# - JWT_SECRET: openssl rand -hex 32
# - SECRET_KEY: openssl rand -hex 32
# - DB_PASSWORD: openssl rand -base64 32
# - REDIS_PASSWORD: openssl rand -base64 24
# - MEDCODE_ENCRYPTION_KEY: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
